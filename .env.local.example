# Base URL of the FastAPI backend — the frontend only ever talks to this.
# It never calls Twelve Data, CoinGecko, or Angel One directly.
NEXT_PUBLIC_API_BASE_URL=

# Firebase Web API Key — used ONLY for the client-side password reset flow
# (Firebase Identity Toolkit REST API). Find it in Firebase Console >
# Project Settings > General > Web API Key. Safe to expose client-side.
NEXT_PUBLIC_FIREBASE_API_KEY=
